@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject Frontend.Services.AuthService AuthService
@inject Frontend.Services.ApiService ApiService
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Nimatic</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (!loaded)
        {
            <div class="nav-item px-3">
                <span class="nav-link">Loading...</span>
            </div>
        }
        else if (!isLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">
                    Login
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/dashboard">
                    Dashboard
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/Settings">
                    Settings
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <button class="btn btn-outline-danger w-100" @onclick="Logout">
                    Logout
                </button>
            </div>
        }
    </nav>
</div>

@code {
    private bool isLoggedIn;
    private bool loaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || loaded)
            return;

        loaded = true;

        var token = await AuthService.GetTokenAsync();
        isLoggedIn = !string.IsNullOrWhiteSpace(token);

        if (isLoggedIn)
        {
            ApiService.SetToken(token);
        }

        StateHasChanged();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        isLoggedIn = false;
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}