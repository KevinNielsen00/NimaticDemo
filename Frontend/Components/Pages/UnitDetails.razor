@page "/unit/{Id:guid}"
@using Frontend.Models
@rendermode InteractiveServer
@inject Frontend.Services.ApiService ApiService
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation

<h3>Unit Details</h3>

@if (isLoading)
{
    <p>Loading measurements...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}
else if (measurements.Count == 0)
{
    <p>No measurements found for this unit.</p>
}
else
{
    <div class="card mb-4 p-3 shadow-sm">
        <h5>Latest Measurement</h5>

        @if (latestMeasurement is not null)
        {
            <div class="barrel-section mb-3">
                <div class="barrel">
                    <div class="barrel-fill @GetLevelClass(latestMeasurement.FillPercentage)"
                         style="height:@latestMeasurement.FillPercentage.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%">
                    </div>
                </div>

                <div>
                    <h2>@latestMeasurement.FillPercentage.ToString("0")%</h2>
                    <p class="mb-1"><b>Status:</b> @GetLevelText(latestMeasurement.FillPercentage)</p>
                    <p class="mb-0"><b>Distance:</b> @latestMeasurement.Depth cm</p>
                </div>
            </div>
        }

        <p><b>Depth:</b> @latestMeasurement?.Depth</p>
        <p><b>Restarts:</b> @latestMeasurement?.Restarts</p>
        <p><b>Battery:</b> @latestMeasurement?.Battery</p>
        <p><b>Temperature:</b> @(latestMeasurement?.Temperature.ToString("0.0")) °C</p>
        <p>
            <b>Measured At:</b>
            @(latestMeasurement is null ? "" : FormatMeasuredAt(latestMeasurement.MeasuredAt))
        </p>
    </div>

    <h5>Measurement History</h5>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Level</th>
                <th>Depth</th>
                <th>Restarts</th>
                <th>Battery</th>
                <th>Temperature</th>
                <th>Measured At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var measurement in measurements)
            {
                <tr>
                    <td>
                        <span class="badge @GetBadgeClass(measurement.FillPercentage)">
                            @measurement.FillPercentage.ToString("0")%
                        </span>
                    </td>
                    <td>@measurement.Depth</td>
                    <td>@measurement.Restarts</td>
                    <td>@measurement.Battery</td>
                    <td>@measurement.Temperature.ToString("0.0") °C</td>
                    <td>@FormatMeasuredAt(measurement.MeasuredAt)</td>
                </tr>
            }
        </tbody>
    </table>
}

<style>
    .barrel-section {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .barrel {
        width: 90px;
        height: 180px;
        border: 3px solid #222;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        background: #f8f9fa;
    }

    .barrel-fill {
        width: 100%;
        transition: height 0.5s ease;
    }

    .level-red {
        background: #dc3545;
    }

    .level-yellow {
        background: #ffc107;
    }

    .level-green {
        background: #198754;
    }
</style>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private List<MeasurementDto> measurements = new();
    private MeasurementDto? latestMeasurement;
    private bool isLoading = true;
    private string? errorMessage;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadMeasurementsAsync();

        hubConnection = new HubConnectionBuilder()
            .WithUrl("http://207.127.93.56:5000/measurementHub")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<Guid>("MeasurementUpdated", async unitId =>
        {
            if (unitId == Id)
            {
                await LoadMeasurementsAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
    }

    private async Task LoadMeasurementsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            measurements = await ApiService.GetMeasurementsAsync(Id);
            latestMeasurement = measurements.FirstOrDefault();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private string GetLevelClass(double percentage)
    {
        if (percentage < 15) return "level-red";
        if (percentage <= 35) return "level-yellow";
        return "level-green";
    }

    private string GetBadgeClass(double percentage)
    {
        if (percentage < 15) return "bg-danger";
        if (percentage <= 35) return "bg-warning text-dark";
        return "bg-success";
    }

    private string GetLevelText(double percentage)
    {
        if (percentage < 15) return "Low level";
        if (percentage <= 35) return "Medium level";
        return "High level";
    }

    private string FormatMeasuredAt(DateTime measuredAt)
    {
        var utcTime = DateTime.SpecifyKind(measuredAt, DateTimeKind.Utc);

        return utcTime
            .ToLocalTime()
            .ToString("dd/MM/yyyy HH:mm:ss");
    }
}