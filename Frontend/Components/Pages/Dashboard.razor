@page "/dashboard"
@using Frontend.Models
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject Frontend.Services.ApiService ApiService
@inject Frontend.Services.AuthService AuthService
@inject NavigationManager Navigation
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client

<h3>Dashboard</h3>

@if (isLoading)
{
    <p>Loading units...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (units.Count == 0)
{
    <p>No units found.</p>
}
else
{
    <div class="row">
        @foreach (var unit in units)
        {
            var latest = latestMeasurements.GetValueOrDefault(unit.Id);

            <div class="col-md-4 mb-3">
                <div class="card shadow-sm p-3">
                    <h5>@(unit.UnitName ?? "Unnamed Unit")</h5>

                    @if (latest is null)
                    {
                        <span class="badge bg-secondary mb-2">No data</span>
                        <p>No measurements yet</p>
                    }
                    else
                    {
                        <span class="badge @GetStatusBadgeClass(latest.FillPercentage) mb-2">
                            @GetStatusText(latest.FillPercentage)
                        </span>

                        <h2>@latest.FillPercentage.ToString("0")% Full</h2>

                        <p class="mb-1">
                            <b>Status:</b> @GetStatusDescription(latest.FillPercentage)
                        </p>

                        <p class="mb-1">
                            <b>Last update:</b>
                            @GetTimeAgo(latest.MeasuredAt)
                        </p>
                    }

                    <button class="btn btn-primary mt-2"
                            @onclick="() => GoToUnit(unit.Id)">
                        View Data
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<UnitDto> units = new();
    private Dictionary<Guid, MeasurementDto?> latestMeasurements = new();

    private bool isLoading = true;
    private string? errorMessage;
    private bool loaded;
    private HubConnection? hubConnection;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || loaded)
            return;

        loaded = true;

        try
        {
            var token = await AuthService.GetTokenAsync();

            if (string.IsNullOrWhiteSpace(token))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            ApiService.SetToken(token);

            await LoadDashboardData();

            hubConnection = new HubConnectionBuilder()
                .WithUrl("http://91.98.30.56:5000/measurementHub")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<Guid>("MeasurementUpdated", unitId =>
            {

                return InvokeAsync(async () =>
                {
                    await LoadLatestMeasurementForUnit(unitId);
                    StateHasChanged();
                });
            });

            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDashboardData()
    {
        units = await ApiService.GetUnitsAsync();

        latestMeasurements.Clear();

        foreach (var unit in units)
        {
            await LoadLatestMeasurementForUnit(unit.Id);
        }
    }

    private async Task LoadLatestMeasurementForUnit(Guid unitId)
    {
        var measurements = await ApiService.GetMeasurementsAsync(unitId);
        latestMeasurements[unitId] = measurements.FirstOrDefault();
    }

    private string GetStatusBadgeClass(double percentage)
    {
        if (percentage < 15) return "bg-danger";
        if (percentage <= 35) return "bg-warning text-dark";
        return "bg-success";
    }

    private string GetStatusText(double percentage)
    {
        if (percentage < 15) return "Critical";
        if (percentage <= 35) return "Needs Attention";
        return "Good";
    }

    private void GoToUnit(Guid unitId)
    {
        Navigation.NavigateTo($"/unit/{unitId}");
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private string GetStatusDescription(double percentage)
    {
        if (percentage < 15)
            return "Barrel is almost empty";

        if (percentage <= 35)
            return "Barrel is getting low";

        return "Barrel level is good";
    }

    private string GetTimeAgo(DateTime measuredAt)
    {
        var span = DateTime.UtcNow - measuredAt;

        if (span.TotalSeconds < 60)
            return $"{(int)span.TotalSeconds} seconds ago";

        if (span.TotalMinutes < 60)
            return $"{(int)span.TotalMinutes} minute{((int)span.TotalMinutes == 1 ? "" : "s")} ago";

        if (span.TotalHours < 24)
            return $"{(int)span.TotalHours} hour{((int)span.TotalHours == 1 ? "" : "s")} ago";

        return $"{(int)span.TotalDays} day{((int)span.TotalDays == 1 ? "" : "s")} ago";
    }
}