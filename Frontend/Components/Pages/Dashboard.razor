@page "/dashboard"
@using Frontend.Models
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject Frontend.Services.ApiService ApiService
@inject Frontend.Services.AuthService AuthService
@inject NavigationManager Navigation
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client

<h3>Dashboard</h3>

@if (isLoading)
{
    <p>Loading units...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (units.Count == 0)
{
    <p>No units found.</p>
}
else
{
    <div class="row">
        @foreach (var unit in units)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm p-3">
                    <h5>@(unit.UnitName ?? "Unnamed Unit")</h5>
                    <p><b>MAC:</b> @unit.MacAddress</p>
                    <p><b>Location:</b> @unit.Location</p>

                    <button class="btn btn-primary"
                            @onclick="() => GoToUnit(unit.Id)">
                        View Data
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<UnitDto> units = new();
    private bool isLoading = true;
    private string? errorMessage;
    private bool loaded;

    private HubConnection? hubConnection;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || loaded)
            return;

        loaded = true;

        try
        {
            var token = await AuthService.GetTokenAsync();

            if (string.IsNullOrWhiteSpace(token))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            ApiService.SetToken(token);
            units = await ApiService.GetUnitsAsync();

            hubConnection = new HubConnectionBuilder()
                .WithUrl("http://207.127.93.56:5000/measurementHub")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<Guid>("MeasurementUpdated", async unitId =>
            {
                units = await ApiService.GetUnitsAsync();
                await InvokeAsync(StateHasChanged);
            });

            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private void GoToUnit(Guid unitId)
    {
        Navigation.NavigateTo($"/unit/{unitId}");
    }

}