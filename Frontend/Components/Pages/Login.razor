@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Frontend.Models
@inject Frontend.Services.AuthService AuthService
@inject Frontend.Services.ApiService ApiService
@inject NavigationManager Navigation

<h3>Login</h3>

<div class="mb-3">
    <label class="form-label">Email</label>
    <input class="form-control" @bind="model.Email" />
</div>

<div class="mb-3">
    <label class="form-label">Password</label>
    <input class="form-control" type="password" @bind="model.Password" />
</div>

<button class="btn btn-primary" @onclick="LoginAsync" disabled="@isLoading">
    @(isLoading ? "Logger ind..." : "Login")
</button>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    private LoginRequestDto model = new();
    private string? errorMessage;
    private bool isLoading;
    private bool checkedLoginState;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || checkedLoginState)
            return;

        checkedLoginState = true;

        var token = await AuthService.GetTokenAsync();

        if (!string.IsNullOrWhiteSpace(token))
        {
            ApiService.SetToken(token);
            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
    }

    private async Task LoginAsync()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            var result = await AuthService.LoginAsync(model);

            if (result is null || string.IsNullOrWhiteSpace(result.Token))
            {
                errorMessage = "Login failed. Check email and password.";
                return;
            }

            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}